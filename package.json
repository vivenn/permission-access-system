{
  "name": "permission-access-system",
  "version": "0.1.0",
  "description": "Reusable permission access system for Node.js and TypeScript apps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivenn/permission-access-system.git"
  },
  "homepage": "https://github.com/vivenn/permission-access-system",
  "bugs": {
    "url": "https://github.com/vivenn/permission-access-system/issues"
  },
  "keywords": [
    "authorization",
    "rbac",
    "permissions",
    "access-control",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
